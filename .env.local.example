# ─── Firebase Configuration ──────────────────────────────────────────────────
# Copy this file to .env.local and fill in your Firebase project credentials.
# Without these variables the app works normally using localStorage only.
#
# How to get them:
#   1. Go to https://console.firebase.google.com
#   2. Create a project (or use an existing one)
#   3. Add a Web app  →  copy the firebaseConfig values below
#   4. Enable Firestore Database (Start in test mode for now)
#
# Firestore security rules (paste in Firebase console → Firestore → Rules):
#
#   rules_version = '2';
#   service cloud.firestore {
#     match /databases/{database}/documents {
#       match /{document=**} {
#         allow read, write: if true;   // Change this in production!
#       }
#     }
#   }

VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=
